APP_NAME=SME Back-Office Copilot API
APP_ENV=local
APP_DEBUG=false
APP_API_PREFIX=/api/v1
LOG_FORMAT=pretty
DATABASE_URL=postgresql+asyncpg://sme:sme@localhost:5433/sme_backoffice
DATABASE_ECHO=false
POSTGRES_HOST_PORT=5433
WORKFLOW_QUEUE_MODE=in_process
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_WORKER_CONCURRENCY=2
CELERY_TASK_MAX_RETRIES=3
CELERY_RETRY_BACKOFF_SECONDS=1.0
OUTBOX_DISPATCHER_ENABLED=true
OUTBOX_POLL_INTERVAL_SECONDS=0.5
OUTBOX_BATCH_SIZE=50
OUTBOX_RETRY_BACKOFF_SECONDS=1.0
WORKFLOW_JOB_HEARTBEAT_SECONDS=10
WORKFLOW_JOB_LEASE_SECONDS=45
PROVIDER_RATE_LIMIT_ENABLED=true
PROVIDER_RATE_LIMIT_REDIS_URL=redis://localhost:6379/2
PROVIDER_OCR_REQUESTS_PER_SECOND=5
PROVIDER_LLM_REQUESTS_PER_SECOND=5
PROVIDER_RATE_LIMIT_WAIT_TIMEOUT_SECONDS=30
UPLOAD_STORAGE_ROOT=../data/uploads
UPLOAD_MAX_SIZE_BYTES=20971520
UPLOAD_ALLOWED_MIME_TYPES=["application/pdf","image/png","image/jpeg","text/csv"]
# Use "local" for development. Azure Blob uses a private container and lets
# independent API/worker processes share original document files.
DOCUMENT_STORAGE_PROVIDER=local
AZURE_STORAGE_BLOB_ENDPOINT=
AZURE_STORAGE_CONTAINER=documents
# Local Azure integration only. Use managed identity in Azure Container Apps.
AZURE_STORAGE_CONNECTION_STRING=
OCR_PROVIDER=mock
AZURE_DI_ENDPOINT=
AZURE_DI_KEY=
AZURE_DI_MODEL_ID=prebuilt-layout
LLM_PROVIDER=mock
WORKFLOW_ORCHESTRATION_MODE=custom
LANGGRAPH_CHECKPOINTING_ENABLED=false
LANGGRAPH_RECURSION_LIMIT=25
TRACING_BACKEND=disabled
TRACING_PROJECT_NAME=sme-backoffice-copilot-local
TRACING_REDACTION_ENABLED=true
TRACING_MAX_PAYLOAD_CHARS=4000
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=sme-backoffice-copilot-local
OCR_PREPROCESSING_ENABLED=false
PROVIDER_TIMEOUT_SECONDS=30
PROVIDER_MAX_RETRIES=1
PROVIDER_RETRY_BACKOFF_SECONDS=0
LLM_INPUT_COST_PER_1K_TOKENS_USD=0.00
LLM_OUTPUT_COST_PER_1K_TOKENS_USD=0.00
PROVIDER_ALLOW_CLOUD=false
PROVIDER_ALLOW_SENSITIVE_CLOUD_PAYLOADS=false
PROVIDER_REQUIRE_DEIDENTIFIED_CLOUD_EVALUATION=true
PROVIDER_REDACTION_MAX_CHARS=4000
TESSERACT_BINARY_PATH=tesseract
TESSERACT_LANGUAGE=eng
PADDLEOCR_LANGUAGE=en
CHANDRAOCR_LANGUAGE=en
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.2
# Set hosted CORS origins explicitly; do not use wildcard origins in staging or production.
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://192.168.30.69:3000"]
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_PREFIX=/api/v1
NEXT_PUBLIC_DEV_TENANT_ID=00000000-0000-4000-8000-000000000001
NEXT_PUBLIC_DEV_USER_ID=00000000-0000-4000-8000-000000000101
NEXT_PUBLIC_DEV_USER_ROLE=member
