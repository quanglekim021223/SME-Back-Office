APP_NAME=SME Back-Office Copilot API
APP_ENV=local
APP_DEBUG=false
APP_API_PREFIX=/api/v1
DATABASE_URL=postgresql+asyncpg://sme:sme@localhost:5433/sme_backoffice
POSTGRES_HOST_PORT=5433
UPLOAD_STORAGE_ROOT=../data/uploads
UPLOAD_MAX_SIZE_BYTES=20971520
UPLOAD_ALLOWED_MIME_TYPES=["application/pdf","image/png","image/jpeg","text/csv"]
OCR_PROVIDER=mock
LLM_PROVIDER=mock
OCR_PREPROCESSING_ENABLED=false
PROVIDER_TIMEOUT_SECONDS=30
PROVIDER_MAX_RETRIES=1
PROVIDER_RETRY_BACKOFF_SECONDS=0
LLM_INPUT_COST_PER_1K_TOKENS_USD=0.00
LLM_OUTPUT_COST_PER_1K_TOKENS_USD=0.00
PROVIDER_ALLOW_CLOUD=false
PROVIDER_ALLOW_SENSITIVE_CLOUD_PAYLOADS=false
PROVIDER_REQUIRE_DEIDENTIFIED_CLOUD_EVALUATION=true
PROVIDER_REDACTION_MAX_CHARS=4000
TESSERACT_BINARY_PATH=tesseract
TESSERACT_LANGUAGE=eng
PADDLEOCR_LANGUAGE=en
CHANDRAOCR_LANGUAGE=en
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.2
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://192.168.30.69:3000"]
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_PREFIX=/api/v1
NEXT_PUBLIC_DEV_TENANT_ID=00000000-0000-4000-8000-000000000001
NEXT_PUBLIC_DEV_USER_ID=00000000-0000-4000-8000-000000000101
NEXT_PUBLIC_DEV_USER_ROLE=member
