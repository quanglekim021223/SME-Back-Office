# Deployment template only. Copy values into Azure Container Apps secrets;
# never commit a populated production environment file.
APP_ENV=production
APP_DEBUG=false
APP_API_PREFIX=/api/v1
LOG_FORMAT=json

# Neon pooled connection string, adapted for SQLAlchemy asyncpg.
DATABASE_URL=postgresql+asyncpg://<user>:<password>@<pooled-neon-host>/<database>?ssl=require
DATABASE_ECHO=false
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=2
DATABASE_POOL_TIMEOUT_SECONDS=30

# Upstash TLS URLs only. Production must never use localhost Redis.
WORKFLOW_QUEUE_MODE=celery
CELERY_BROKER_URL=rediss://:<token>@<upstash-host>:6379/0
CELERY_RESULT_BACKEND=rediss://:<token>@<upstash-host>:6379/0
PROVIDER_RATE_LIMIT_ENABLED=true
PROVIDER_RATE_LIMIT_REDIS_URL=rediss://:<token>@<upstash-host>:6379/0
CELERY_WORKER_CONCURRENCY=2
CELERY_TASK_MAX_RETRIES=3
CELERY_RETRY_BACKOFF_SECONDS=1.0
CELERY_BROKER_POLLING_INTERVAL_SECONDS=30
OUTBOX_DISPATCHER_ENABLED=true
OUTBOX_POLL_INTERVAL_SECONDS=5.0
OUTBOX_BATCH_SIZE=50
OUTBOX_RETRY_BACKOFF_SECONDS=1.0
WORKFLOW_JOB_HEARTBEAT_SECONDS=10
WORKFLOW_JOB_LEASE_SECONDS=45
PROVIDER_OCR_REQUESTS_PER_SECOND=5
PROVIDER_LLM_REQUESTS_PER_SECOND=5
PROVIDER_RATE_LIMIT_WAIT_TIMEOUT_SECONDS=30

# Azure Blob uses the Container App managed identity, not an account key.
DOCUMENT_STORAGE_PROVIDER=azure_blob
AZURE_STORAGE_BLOB_ENDPOINT=https://<production-storage-account>.blob.core.windows.net
AZURE_STORAGE_CONTAINER=documents
AZURE_STORAGE_CONNECTION_STRING=

# Provider secrets come from the Container Apps secret store or Key Vault.
OCR_PROVIDER=azure_di
AZURE_DI_ENDPOINT=https://<production-document-intelligence>.cognitiveservices.azure.com/
AZURE_DI_KEY=
AZURE_DI_MODEL_ID=prebuilt-invoice
# Proven staging preset: improve contrast and small skew without destructively
# denoising, thresholding, or upscaling every invoice image.
OCR_PREPROCESSING_ENABLED=true
OCR_PREPROCESSING_DESKEW=true
OCR_PREPROCESSING_DENOISE=false
OCR_PREPROCESSING_BINARIZE=false
OCR_PREPROCESSING_UPSCALE_MIN_PX=0
OCR_PREPROCESSING_CLAHE_CLIP_LIMIT=2.0
OCR_PREPROCESSING_CLAHE_TILE_GRID_SIZE=8
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.2
PROVIDER_ALLOW_CLOUD=true
PROVIDER_ALLOW_SENSITIVE_CLOUD_PAYLOADS=false
PROVIDER_REQUIRE_DEIDENTIFIED_CLOUD_EVALUATION=true

CORS_ORIGINS=["https://<production-frontend-domain>"]
NEXT_PUBLIC_API_URL=https://<production-api-domain>
